   <dc:title>
    <rdf:Alt>
     <rdf:li xml:lang="x-default">Magic explosions, flash with fire and blue smoke</rdf:li>
    </rdf:Alt>
   </dc:title>
   <dc:description>
    <rdf:Alt>
     <rdf:li xml:lang="x-default">Magic explosions, light flash or energy burst with fire and blue smoke clouds. Vector cartoon set of blast effects for 2d game animation isolated on background</rdf:li>
    </rdf:Alt>
   </dc:description>
